# ── Supabase ──────────────────────────────────────────────────────────────────
# Obtené estos valores en: https://supabase.com/dashboard → tu proyecto → Settings → API
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGci...

# ── MercadoPago ───────────────────────────────────────────────────────────────
# Clave pública del frontend (panel MP → Credenciales de producción)
VITE_MP_PUBLIC_KEY=APP_USR-xxxx

# ID de la Edge Function de Supabase que crea la suscripción
# (se completa después de hacer deploy de la Edge Function)
VITE_SUPABASE_FUNCTIONS_URL=https://xxxx.supabase.co/functions/v1

# ── Panel de métricas (/panel) ────────────────────────────────────────────────
# Email de la cuenta con acceso al panel interno de métricas SEO.
VITE_ADMIN_EMAIL=edgardolamas2000@gmail.com

# Variables de la serverless function app/api/search-console.ts (cargar en Vercel,
# NO en el frontend): GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, GOOGLE_REFRESH_TOKEN
# y opcionalmente GSC_SITE (ej: sc-domain:tudominio.com).
